{
  "name": "999",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "node src/sync-sheet.js",
    "sync:card": "node src/sync-card-sheet.js",
    "score": "node src/score-words.js",
    "check:kana": "node src/check-kana.js",
    "check:digits": "node src/check-digits.js",
    "check:errors": "node src/check-errors.js",
    "viz": "node src/generate-viz.js",
    "dev": "portless run vite",
    "dev:raw": "vite",
    "build": "npm run build:data && vite build",
    "build:data": "node src/generate-preview-data.js",
    "start": "npx serve src",
    "preview:legacy": "npx serve public",
    "preview": "portless run vite preview",
    "preview:raw": "vite preview",
    "build:preview": "node src/generate-preview-data.js && cp src/visualize-words.html public/stats.html && cp src/visualize-words.css public/ && cp src/viz-client.js public/ && cp src/visualize-words.data.json public/",
    "deploy:legacy": "npm run build:preview && firebase deploy --only hosting",
    "deploy": "npm run build:preview && npm run build && firebase deploy --only hosting"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "preact": "^10.29.0"
  }
}
